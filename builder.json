                },
                {
                    "id": "required",
                    "type": "bool",
                    "question": "Is your field required?"
                },
                {
                    "id": "start_date",
                    "type": "date",
                    "question": "Start Date:",
                    "required": false
                },
                {
                    "id": "end_date",
                    "type": "date",
                    "question": "End Date:",
                    "required": false
                }
            ]
        },
        "field_type_counter": {
            "fields": [
                {
                    "id": "question",
                    "type": "text",
                    "question": "What is your question?"
                }
            ]
        },
        "field_type_color": {
            "fields": [
                {
                    "id": "question",
                    "type": "text",
                    "question": "What is your question?"
                }
            ]
        },
        "field_type_bool": {
            "fields": [
                {
                    "id": "question",
                    "type": "text",
                    "question": "What is your question?"
                },
                {
                    "id": "required",
                    "type": "bool",
                    "question": "Is your field required?"
                }
            ]
        },
        "field_type_multitext": {
            "fields": [
                {
                    "id": "question",
                    "type": "text",
                    "question": "What is your question?"
                },
                {
                    "id": "required",
                    "type": "bool",
                    "question": "Is your field required?"
                },
                {
                    "id": "placeholder",
                    "type": "text",
                    "question": "Enter some placeholder text.",
                    "placeholder": "(Optional)",
                    "required": false
                },
                {
                    "id": "min",
                    "type": "number",
                    "question": "Min:",
                    "required": false
                },
                {
                    "id": "max",
                    "type": "number",
                    "question": "Max:",
                    "required": false
                },
                {
                    "id": "maxlength",
                    "type": "number",
                    "question": "What is the max length of each option?",
                    "max": 8000,
                    "required": false
                },
                {
                    "id": "pattern",
                    "type": "text",
