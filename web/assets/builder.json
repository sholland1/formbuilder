{
    "id": "builder-form",
    "title": "Build your own form!",
    "forms": {
        "header": {
            "fields": [
                {
                    "id": "id",
                    "type": "text",
                    "label": "Enter an id for your form.",
                    "placeholder": "(example-id)",
                    "pattern": "[a-zA-Z0-9_\\-]+"
                },
                {
                    "id": "title",
                    "type": "text",
                    "label": "What is the title of your form?"
                }
            ]
        },
        "field_start": {
            "fields": [
                {
                    "id": "id",
                    "type": "text",
                    "label": "Enter an id for your field.",
                    "placeholder": "(example-id)",
                    "pattern": "[a-zA-Z0-9_\\-]+"
                },
                {
                    "id": "type",
                    "type": "select",
                    "label": "What type of field?",
                    "options": [
                        "text",
                        "multitext",
                        "number",
                        "select",
                        "multiselect",
                        "timestamp",
                        "date",
                        "counter",
                        "color",
                        "bool",
                        "timer",
                        "guid",
                        "file",
                        "signature",
                        "rating"
                    ]
                }
            ]
        },
        "field_type_text": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                },
                {
                    "id": "placeholder",
                    "type": "text",
                    "label": "Enter some text for a placeholder.",
                    "placeholder": "(Optional)",
                    "required": false
                },
                {
                    "id": "maxlength",
                    "type": "number",
                    "label": "What is the max length of your field?",
                    "max": 8000,
                    "required": false
                },
                {
                    "id": "pattern",
                    "type": "text",
                    "label": "Enter a regular expression to match.",
                    "required": false
                }
            ]
        },
        "field_type_number": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                },
                {
                    "id": "min",
                    "type": "number",
                    "label": "Min:",
                    "required": false,
                    "min": 0
                },
                {
                    "id": "max",
                    "type": "number",
                    "label": "Max:",
                    "required": false,
                    "min": 1
                },
                {
                    "id": "step",
                    "type": "select",
                    "label": "Step:",
                    "options": [
                        "1", "2", "3", "4", "5", "10", "20", "25", "50", "100",
                        "0.1", "0.2", "0.25", "0.5",
                        "0.01", "0.02", "0.025", "0.05",
                        "0.001", "0.002", "0.0025", "0.005",
                        "0.0001", "0.0002", "0.00025", "0.0005"
                    ],
                    "required": false
                }
            ]
        },
        "field_type_select": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                },
                {
                    "id": "options",
                    "type": "multitext",
                    "label": "Enter a list of options separated by commas."
                }
            ]
        },
        "field_type_multiselect": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "options",
                    "type": "multitext",
                    "label": "Enter a list of options separated by commas."
                },
                {
                    "id": "min",
                    "type": "number",
                    "label": "Min:",
                    "required": false,
                    "min": 0
                },
                {
                    "id": "max",
                    "type": "number",
                    "label": "Max:",
                    "required": false,
                    "min": 1
                }
            ]
        },
        "field_type_timestamp": {
            "fields": []
        },
        "field_type_guid": {
            "fields": []
        },
        "field_type_date": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                },
                {
                    "id": "start_date",
                    "type": "date",
                    "label": "Start Date:",
                    "required": false
                },
                {
                    "id": "end_date",
                    "type": "date",
                    "label": "End Date:",
                    "required": false
                }
            ]
        },
        "field_type_counter": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                }
            ]
        },
        "field_type_color": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                }
            ]
        },
        "field_type_bool": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                }
            ]
        },
        "field_type_timer": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                }
            ]
        },
        "field_type_multitext": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "placeholder",
                    "type": "text",
                    "label": "Enter some text for a placeholder.",
                    "placeholder": "(Optional)",
                    "required": false
                },
                {
                    "id": "min",
                    "type": "number",
                    "label": "Min:",
                    "required": false,
                    "min": 0
                },
                {
                    "id": "max",
                    "type": "number",
                    "label": "Max:",
                    "required": false,
                    "min": 1
                },
                {
                    "id": "maxlength",
                    "type": "number",
                    "label": "What is the max length of each option?",
                    "max": 8000,
                    "required": false
                },
                {
                    "id": "pattern",
                    "type": "text",
                    "label": "Enter a regular expression to match for each option.",
                    "required": false
                }
            ]
        },
        "field_type_file": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "maxsize",
                    "type": "number",
                    "label": "Max size in KB:",
                    "required": true
                },
                {
                    "id": "min",
                    "type": "number",
                    "label": "Min:",
                    "required": false,
                    "min": 0
                },
                {
                    "id": "max",
                    "type": "number",
                    "label": "Max:",
                    "required": false,
                    "min": 1
                },
                {
                    "id": "fileexts",
                    "type": "multitext",
                    "label": "Allowed file extensions:",
                    "required": false,
                    "pattern": "^(\\.[a-zA-Z0-9]+)(,(\\.[a-zA-Z0-9]+))*$"
                }
            ]
        },
        "field_type_signature": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                }
            ]
        },
        "field_type_rating": {
            "fields": [
                {
                    "id": "label",
                    "type": "text",
                    "label": "Enter some text for a label."
                },
                {
                    "id": "required",
                    "type": "bool",
                    "label": "Is your field required?"
                },
                {
                    "id": "maxrating",
                    "type": "select",
                    "label": "What is the max rating?",
                    "options": [ "5", "10" ]
                },
                {
                    "id": "step",
                    "type": "select",
                    "label": "Step:",
                    "options": [ "1", "0.1", "0.5" ],
                    "required": false
                }
            ]
        }
    }
}
