{
    "id": "basic-form",
    "title": "My Basic Test Form",
    "fields": [
        {
            "id": "name",
            "type": "text",
            "label": "What is your name?",
            "placeholder": "(John Smith)",
            "maxlength": 16
        },
        {
            "id": "ssn",
            "type": "text",
            "label": "Give me your Social Security Number! Now!!",
            "required": false,
            "placeholder": "(000-00-0000)",
            "pattern": "^\\d{3}-\\d{2}-\\d{4}$"
        },
        {
            "id": "age",
            "type": "number",
            "label": "How old are you?",
            "required": false,
            "min": 0,
            "max": 127
        },
        {
            "id": "weight",
            "type": "number",
            "label": "How much do you weigh?",
            "required": false,
            "min": 0,
            "max": 1023,
            "step": 0.1
        },
        {
            "id": "ice_cream_flavor",
            "type": "select",
            "label": "What is your favorite ice cream flavor?",
            "required": false,
            "options": [
                "vanilla",
                "chocolate",
                "strawberry",
                "neapolitan"
            ]
        },
        {
            "id": "sports",
            "type": "multiselect",
            "label": "What sports do you play?",
            "options": [
                "basketball",
                "baseball",
                "gymnastics",
                "football",
                "soccer",
                "hockey",
                "tennis",
                "pickleball"
            ],
            "min": 1,
            "max": 3
        },
        {
            "id": "timestamp",
            "type": "timestamp"
        },
        {
            "id": "date_of_birth",
            "type": "date",
            "label": "Enter your date of birth.",
            "required": false,
            "start_date": "1900-01-01",
            "end_date": "2026-02-28"
        },
        {
            "id": "some_count",
            "type": "counter",
            "label": "Count something, would ya?"
        },
        {
            "id": "favorite_color",
            "type": "color",
            "label": "What is your favorite color?"
        },
        {
            "id": "happy",
            "type": "bool",
            "label": "Are you happy?"
        },
        {
            "id": "video_games",
            "type": "multitext",
            "label": "What are some of your favorite video games?",
            "placeholder": "(Enter a list of options separated by commas.)"
        },
        {
            "id": "breath_held",
            "type": "timer",
            "label": "How long can you hold your breath?"
        },
        {
            "id": "guid",
            "type": "guid"
        },
        {
            "id": "files",
            "type": "file",
            "label": "Upload your files...",
            "maxsize": 1024,
            "min": 1,
            "max": 3,
            "fileexts": [
                ".html",
                ".json",
                ".c"
            ]
        },
        {
            "id": "signature",
            "type": "signature",
            "label": "Sign on the dotted line. ;)"
        }
    ]
}
